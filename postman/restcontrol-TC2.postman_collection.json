        {
          "name": "Create User Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) {",
                  "    pm.collectionVariables.set('userTypeId', data.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{$randomJobType}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/userstypes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "user-types"
              ]
            }
          }
        },
